# ─────────────────────────────────────────────────────────
# One Question a Day — 환경 변수 템플릿
# 이 파일을 복사해서 .env.local을 만드세요.
# ─────────────────────────────────────────────────────────

# ─── Supabase ───
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# ⚠️ SERVICE_ROLE은 절대 클라이언트 코드에 노출 금지. 서버 API route 전용.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── App ───
# 프로덕션: https://onequestionaday.com
# 로컬: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── 세션 해시 ───
# 매일 UTC 00:00에 교체되는 솔트의 "기본 시크릿"
# 32자 이상의 랜덤 문자열. `openssl rand -base64 48`로 생성
SESSION_HASH_SECRET=replace-with-random-48-byte-secret

# ─── 개발 모드 ───
# 로컬에서 CF-IPCountry 헤더가 없으므로 시뮬레이션용
# 프로덕션에서는 반드시 비워두거나 삭제
DEV_COUNTRY_OVERRIDE=KR

# ─── 분석 (선택) ───
# Plausible 대시보드에 등록한 도메인. 값이 있으면 스크립트가 자동 삽입됩니다.
# 로컬에서는 비워두는 것을 권장 (localhost 트래픽을 Plausible 에 보낼 필요 없음).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ─── 모니터링 (선택) ───
# Sentry DSN. 값이 있으면 server/edge/client 모두 Sentry 로 전송합니다.
# 서버 전용: SENTRY_DSN (instrumentation.ts 에서 init)
# 클라이언트: NEXT_PUBLIC_SENTRY_DSN (instrumentation-client.ts 에서 init)
# 소스맵 업로드: SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN (빌드 시)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Cron ───
# Vercel Cron 이 매일 UTC 00:00 /api/cron/rotate-questions 를 호출할 때
# 붙이는 bearer 토큰. Vercel 대시보드에서 env 에 값을 넣으면 Vercel 이
# 자동으로 `Authorization: Bearer <CRON_SECRET>` 를 붙입니다.
# 16자 이상 (openssl rand -base64 32).
CRON_SECRET=

# ─── 이메일 (Phase 2+) ───
# Resend 등 트랜잭셔널 이메일 서비스
RESEND_API_KEY=

# ─── 관리자 ───
# Basic Auth 비밀번호 (16자 이상). 비우면 /admin 및 /api/admin/* 은 503.
ADMIN_TOKEN=
ADMIN_EMAILS=you@example.com
