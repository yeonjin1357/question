{
  "name": "one-question-a-day",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:check": "node scripts/i18n-check.mjs",
    "a11y": "node scripts/a11y-check.mjs",
    "db:types": "supabase gen types typescript --project-id qfpkgwuldwjvdgmubhzz --schema public > src/types/database.ts",
    "db:migrate": "supabase migration up",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:seed": "supabase db reset --no-seed=false"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.49.0",
    "@supabase/supabase-js": "^2.103.3",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "14.2.35",
    "next-intl": "^4.9.1",
    "react": "^18",
    "react-dom": "^18",
    "react-simple-maps": "^3.0.0",
    "server-only": "^0.0.1",
    "world-atlas": "^2.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-simple-maps": "^3.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.92.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
